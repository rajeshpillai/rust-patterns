%% Iterator adapters compose lazily. Nothing runs until a *consumer*
%% (collect, sum, for_each, count, ...) pulls from the chain.
flowchart LR
    Src[vec![1, 2, 3, 4, 5]] --> I1[.iter()]
    I1 --> M1[".map(|x| x * x)"]
    M1 --> F1[".filter(|&n| n &gt; 4)"]
    F1 --> C1{consumer?}
    C1 -->|.collect::&lt;Vec&lt;_&gt;&gt;()| Vec1[vec![9, 16, 25]]
    C1 -->|.sum::&lt;i32&gt;()| Sum[50]
    C1 -->|.count()| Cnt[3]

    note1["Everything is LAZY.<br/>map() and filter() return<br/>adapter structs, not results.<br/>The consumer drives the chain."]
    F1 -.-> note1
