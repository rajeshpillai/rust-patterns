    note1["eval(Mul(a,b)) = eval(a) * eval(b)<br/>eval(Add(a,b)) = eval(a) + eval(b)<br/>eval(Var k)    = env[k]<br/>eval(Num n)    = n<br/>result: (3 + 2) * 5 = 25"]
