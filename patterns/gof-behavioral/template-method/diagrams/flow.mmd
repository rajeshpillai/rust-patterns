%% run() is the template. Its body calls the abstract steps in order;
%% each impl supplies the bodies of those steps.
sequenceDiagram
    participant Caller
    participant T as "trait DataPipeline::run (default)"
    participant I as "impl CsvPipeline"

    Caller->>T: run(path)
    T->>I: self.load(path)
    I-->>T: Ok(bytes)
    T->>I: self.parse(bytes)
    I-->>T: Ok(records)
    T->>I: self.validate(records)
    I-->>T: Ok(records)
    T->>I: self.emit(records)
    I-->>T: text
    T-->>Caller: Ok(text)
