%% Parse, don't validate — the value that arrives in a domain function
%% has already been proven legal by its type.
sequenceDiagram
    autonumber
    participant UI as User Input
    participant Parser as EmailAddress::parse
    participant Svc as send_welcome(to: EmailAddress)

    UI->>Parser: "rajesh@example.com"
    alt valid
        Parser-->>UI: Ok(EmailAddress)
        UI->>Svc: send_welcome(email)
        Note right of Svc: the function body never<br/>re-validates — the TYPE<br/>proves it was valid
        Svc-->>UI: Ok(())
    else invalid
        Parser-->>UI: Err(InvalidEmail)
        Note right of UI: impossible to call<br/>send_welcome("not an email")
    end
